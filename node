worker thread
// main.js
const { Worker } = require('worker_threads')
const worker = new Worker('./heavy-task.js')
worker.on('message', result => console.log(result))

// heavy-task.js  вҶҗ runs in its OWN V8 + Event Loop
const { parentPort } = require('worker_threads')
// actual JS runs here вҖ” loops, parsing, anything
let result = doHeavyCPUWork()
parentPort.postMessage(result)

Each Worker Thread has its own V8 instance + own Event Loop вҖ” completely isolated from the main thread.

